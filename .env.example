APP_NAME="Clash of Dots"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Verbose match simulation logs (orders, tick skips, active-set repair). Off unless debugging.
# GAME_SIM_LOG=true
# Sail: use the host URL you open in the browser (matches published APP_PORT, default 80).
APP_URL=http://localhost
# Production: https://www.clashofdots.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database — Sail: hostname is the Compose service `pgsql` (see compose.yaml).
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

# Optional: SQLite for a zero-service local DB (not used in CI; PHPUnit still uses in-memory SQLite).
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# Broadcasting — Sail: PHP talks to the `reverb` container; the browser uses VITE_* (localhost + published port).
# Compose overrides DB_HOST / REDIS_HOST / REVERB_HOST / VITE_REVERB_* in containers so `sail up` works without hand-editing.
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb
# If you run without Reverb at all: BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

REVERB_APP_ID=clashofdots
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
# PHP (Artisan, queue, game tick) → Reverb HTTP API. Sail Compose sets this to `reverb` automatically.
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
# In production, set this to your APP_URL to restrict WebSocket CORS. Leave unset to default to APP_URL.
# REVERB_APP_ALLOWED_ORIGINS=https://clashofdots.com

# Browser (Echo) → host machine → published Reverb port (must NOT be the Docker service name).
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis — Sail: hostname is the Compose service `redis`. Compose injects `redis` in containers.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Must match APP_URL host and be registered in the WorkOS dashboard redirect URIs.
WORKOS_REDIRECT_URL="${APP_URL}/authenticate"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Vite HMR: set true when assets do not hot-reload (Docker / Sail bind mounts, some network FS).
# VITE_USE_POLLING=true

# If PHP runs in Sail but Vite runs on the host, set the public URL of the dev server (see Laravel Sail docs).
# If the browser tries to load `http://[::]:5173` and assets fail, use an explicit loopback URL, e.g.:
# VITE_DEV_SERVER_URL=http://127.0.0.1:5173
